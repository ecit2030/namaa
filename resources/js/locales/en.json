    "faq": {
        "sectionTitle": "FAQ",
        "subtitle": "Frequently asked questions",
        "items": [
            {"question": "How can I book a consultation?", "answer": "Browse available consultants, choose the right one, then set the consultation type (video/audio/text) and your preferred time. After secure payment, you'll receive a booking confirmation and contact details."},
            {"question": "What types of services are available?", "answer": "We offer financial and accounting consulting, feasibility studies, market analysis, financial planning, financial statements, tax consulting, and project valuation."},
            {"question": "How are consultants vetted?", "answer": "All consultants are verified for academic qualifications, professional certifications, and practical experience before joining the platform."},
            {"question": "How do consultants receive their earnings?", "answer": "Consultants receive earnings periodically (weekly or monthly) via bank transfer or the in-app e-wallet."},
            {"question": "Are consultations confidential and secure?", "answer": "Yes. All consultations and data are protected with modern encryption and strict privacy policies."},
            {"question": "What if I have a technical issue during a consultation?", "answer": "Contact support 24/7 via in-app chat or email. We resolve issues promptly and reschedule when needed."}
        ]
    },
